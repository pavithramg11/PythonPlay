    "yt = np.array([10,20,30])\n",
    "yp = np.array([12,18,33])\n",
    "\n",
    "diff = np.array(yt-yp)\n",
    "\n",
    "diff2 = np.array(diff**2)\n",
    "\n",
    "mse = np.sum(diff2)/3;\n",
    "\n",
    "print(\"mse = \", mse)"
